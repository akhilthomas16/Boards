# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DATABASE_URL=postgres://boards_user:boards_pass@localhost:5432/boards_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM (OpenAI-compatible)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Google Ads
GOOGLE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
GOOGLE_ADSENSE_SLOT_BANNER=1234567890
GOOGLE_ADSENSE_SLOT_SIDEBAR=0987654321
GOOGLE_ADSENSE_SLOT_INFEED=1122334455

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Wagtail
WAGTAIL_SITE_NAME=Boards CMS

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
